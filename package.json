{
  "name": "unistockwms-agent",
  "version": "0.1.0",
  "description": "Agente local que pollea jobs PENDING desde Railway y manda ZPL a las Zebras de la LAN del depo.",
  "private": true,
  "main": "dist/index.js",
  "bin": {
    "unistock-agent": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "package": "pkg dist/index.js --targets node20-win-x64,node20-linux-x64 --out-path bin"
  },
  "dependencies": {
    "axios": "^1.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
